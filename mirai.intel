<script>	Intel::ADDR	MIRAI	F	Malicious
(function () {	Intel::ADDR	MIRAI	F	Malicious
// Ambil data dari JSON-LD yang kamu tempel (type="application/ld+json")	Intel::ADDR	MIRAI	F	Malicious
const ldScripts = Array.from(document.querySelectorAll('script[type="application/ld+json"]'));	Intel::ADDR	MIRAI	F	Malicious
const org = ldScripts	Intel::ADDR	MIRAI	F	Malicious
.map(s => {	Intel::ADDR	MIRAI	F	Malicious
try { return JSON.parse(s.textContent.trim()); } catch (e) { return null; }	Intel::ADDR	MIRAI	F	Malicious
})	Intel::ADDR	MIRAI	F	Malicious
.find(o => o && (o["@type"] === "Organization") && Array.isArray(o.review));	Intel::ADDR	MIRAI	F	Malicious
const reviews = org?.review || [];	Intel::ADDR	MIRAI	F	Malicious
const track = document.getElementById("reviewTrack");	Intel::ADDR	MIRAI	F	Malicious
if (!track || !reviews.length) return;	Intel::ADDR	MIRAI	F	Malicious
// Render card	Intel::ADDR	MIRAI	F	Malicious
const makeStars = (val) => {	Intel::ADDR	MIRAI	F	Malicious
const rating = Math.max(0, Math.min(5, Number(val) || 0));	Intel::ADDR	MIRAI	F	Malicious
const full = Math.round(rating); // simple rounding	Intel::ADDR	MIRAI	F	Malicious
return `	Intel::ADDR	MIRAI	F	Malicious
<span class="stars" aria-label="Rating ${rating} dari 5">	Intel::ADDR	MIRAI	F	Malicious
${Array.from({ length: 5 }).map((_, i) => `<span class="star ${i < full ? '' : 'off'}"></span>`).join('')}	Intel::ADDR	MIRAI	F	Malicious
</span>`;	Intel::ADDR	MIRAI	F	Malicious
};	Intel::ADDR	MIRAI	F	Malicious
const fmtDate = (iso) => {	Intel::ADDR	MIRAI	F	Malicious
if (!iso) return "";	Intel::ADDR	MIRAI	F	Malicious
const d = new Date(iso);	Intel::ADDR	MIRAI	F	Malicious
if (isNaN(d)) return iso;	Intel::ADDR	MIRAI	F	Malicious
return d.toLocaleDateString("id-ID", { year: "numeric", month: "short", day: "2-digit" });	Intel::ADDR	MIRAI	F	Malicious
};	Intel::ADDR	MIRAI	F	Malicious
const cardsHTML = reviews.map(r => {	Intel::ADDR	MIRAI	F	Malicious
const author = r?.author?.name ?? "Anonim";	Intel::ADDR	MIRAI	F	Malicious
const title = r?.name ?? "Review";	Intel::ADDR	MIRAI	F	Malicious
const body = r?.reviewBody ?? "";	Intel::ADDR	MIRAI	F	Malicious
const date = fmtDate(r?.datePublished);	Intel::ADDR	MIRAI	F	Malicious
const rating = r?.reviewRating?.ratingValue ?? 5;	Intel::ADDR	MIRAI	F	Malicious
return `	Intel::ADDR	MIRAI	F	Malicious
<article class="review-card">	Intel::ADDR	MIRAI	F	Malicious
<div class="review-card__top">	Intel::ADDR	MIRAI	F	Malicious
<p class="review-card__name">${author}</p>	Intel::ADDR	MIRAI	F	Malicious
<div class="review-card__meta">	Intel::ADDR	MIRAI	F	Malicious
${makeStars(rating)}	Intel::ADDR	MIRAI	F	Malicious
<span aria-label="Tanggal">${date}</span>	Intel::ADDR	MIRAI	F	Malicious
</div>	Intel::ADDR	MIRAI	F	Malicious
</div>	Intel::ADDR	MIRAI	F	Malicious
<h3 class="review-card__title">${title}</h3>	Intel::ADDR	MIRAI	F	Malicious
<p class="review-card__body">${body}</p>	Intel::ADDR	MIRAI	F	Malicious
</article>	Intel::ADDR	MIRAI	F	Malicious
`;	Intel::ADDR	MIRAI	F	Malicious
}).join("");	Intel::ADDR	MIRAI	F	Malicious
// Trick infinite loop:	Intel::ADDR	MIRAI	F	Malicious
// - Isi track dengan 2x konten yang sama	Intel::ADDR	MIRAI	F	Malicious
// - Animasi translateX dari 0 ke -50%	Intel::ADDR	MIRAI	F	Malicious
track.innerHTML = cardsHTML + cardsHTML;	Intel::ADDR	MIRAI	F	Malicious
// Stabilkan kecepatan berdasarkan jumlah card (opsional, biar tidak terlalu cepat saat sedikit review)	Intel::ADDR	MIRAI	F	Malicious
const count = reviews.length;	Intel::ADDR	MIRAI	F	Malicious
const root = document.documentElement;	Intel::ADDR	MIRAI	F	Malicious
const base = 18; // detik	Intel::ADDR	MIRAI	F	Malicious
const perCard = 4; // detik per card	Intel::ADDR	MIRAI	F	Malicious
const speed = Math.max(base, Math.min(90, base + (count * perCard)));	Intel::ADDR	MIRAI	F	Malicious
root.style.setProperty("--speed", speed + "s");	Intel::ADDR	MIRAI	F	Malicious
})();	Intel::ADDR	MIRAI	F	Malicious
</script>	Intel::ADDR	MIRAI	F	Malicious
